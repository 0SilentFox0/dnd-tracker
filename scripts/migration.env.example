# Скопіюй цей файл як .env.migration і заповни значеннями
# .env.migration в .gitignore — не потрапить у репозиторій

# Старий Supabase проект (звідки експортуємо)
# Dashboard → Project Settings → Database → Connection string → Direct connection
OLD_DB_URL="postgresql://postgres.[OLD_PROJECT_REF]:[PASSWORD]@db.[OLD_PROJECT_REF].supabase.co:5432/postgres"

# Новий Supabase проект (куди імпортуємо)
# Dashboard → Project Settings → Database → Connection string → Direct connection
NEW_DB_URL="postgresql://postgres.[NEW_PROJECT_REF]:[PASSWORD]@db.[NEW_PROJECT_REF].supabase.co:5432/postgres"
