# Скопіюй у .env.local і заповни. Для Vercel — ті самі ключі в Dashboard → Environment Variables.

# Prisma / PostgreSQL (Supabase pooler 6543 + pgbouncer=true рекомендовано для Vercel)
DATABASE_URL="postgresql://..."

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Pusher (опційно; без них бій працює без live-оновлень)
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Опційно: Redis-кеш для довідкових запитів (lib/cache/kv.ts)
# Можна підключити через Vercel Marketplace (Redis Cloud) або власний redis.
# REDIS_URL="redis://default:password@host:port"

# Опційно: Upstash Redis (REST API) — для rate limiting на battle endpoints
# (lib/utils/api/rate-limit.ts) і потенційно cache. Ідеально для Vercel
# serverless (HTTP без persistent TCP). Free tier 10k requests/day.
# Знайти у Upstash console → Database → REST API → Endpoint URL + Token.
# UPSTASH_REDIS_REST_URL="https://xxx-xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# Дев: логи таймінгу ходів
# NEXT_PUBLIC_BATTLE_TURN_TIMING=1
# BATTLE_TURN_TIMING=1
